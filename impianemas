      color: #B2EBF2;
    }
    .teacher-card {
      background: var(--beige);
      border-radius: 12px;
      padding: 20px 16px;
      border-bottom: 3px solid var(--green);
    }
    .teacher-subject {
      font-size: 13px; font-weight: 700;
      color: var(--white);
      background: var(--green);
      display: inline-block;
      padding: 3px 12px;
      border-radius: 20px;
      margin-bottom: 10px;
    }
    .teacher-card h3 { font-size: 18px; font-weight: 800; color: var(--dark); margin-bottom: 8px; }
    .teacher-card ul { list-style: none; }
    .teacher-card ul li {
      font-size: 14px; color: #555;
      padding: 3px 0;
      padding-left: 16px;
      position: relative;
    }
    .teacher-card ul li::before {
      content: '✦';
      position: absolute; left: 0;
      color: var(--gold);
      font-size: 10px;
      top: 5px;
    }
    .teacher-highlight {
      background: linear-gradient(135deg, #0097A7, #00606A);
      color: #fff;
    }
    .teacher-highlight .teacher-photo {
      background: rgba(255,255,255,0.15);
      border-color: rgba(255,255,255,0.5);
    }
    .teacher-highlight .teacher-photo .photo-placeholder { color: rgba(255,255,255,0.4); }

    /* ─── PHOTO GALLERY ─── */
    #gallery { background: var(--beige); }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    @media (min-width: 600px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }
    .gallery-slot {
      background: #E0F7FA;
      border-radius: 12px;
      aspect-ratio: 4/3;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 8px;
      border: 2px dashed #80DEEA;
      cursor: pointer;
      transition: background .2s;
      overflow: hidden;
      position: relative;
    }
    .gallery-slot img {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover;
      border-radius: 10px;
    }
    .gallery-slot .slot-label {
      font-size: 13px; color: #00838F; font-weight: 600;
      text-align: center; padding: 0 12px;
    }
    .gallery-slot .slot-icon { font-size: 32px; }
    .gallery-slot-wide {
      grid-column: 1 / -1;
      aspect-ratio: 16/7;
    }
