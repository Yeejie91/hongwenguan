    .pain-icon { font-size: 34px; flex-shrink: 0; margin-top: 2px; }
    .pain-card h3 { font-size: 18px; font-weight: 700; color: var(--dark); margin-bottom: 6px; }
    .pain-card p  { font-size: 16px; color: var(--muted); line-height: 1.7; }

    /* ─── WHY US ─── */
    #why .why-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .why-card {
      background: var(--white);
      border-radius: 14px;
      padding: 24px 22px;
      box-shadow: 0 2px 14px rgba(0,0,0,0.07);
