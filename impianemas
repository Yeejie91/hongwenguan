      color: #fff;
    }
    .course-panel { display: none; }
    .course-panel.active { display: block; }
    .schedule-table {
      width: 100%;
      border-collapse: collapse;
      border-radius: 12px;
      overflow: hidden;
      font-size: 16px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .schedule-table thead { background: var(--green); color: #fff; }
    .schedule-table th { padding: 14px 16px; text-align: left; font-size: 15px; }
    .schedule-table tbody tr:nth-child(even) { background: #E0F7FA; }
    .schedule-table tbody tr:nth-child(odd)  { background: #fff; }
    .schedule-table td { padding: 13px 16px; border-bottom: 1px solid #B2EBF2; vertical-align: middle; }
    .schedule-table td strong { color: var(--green); font-weight: 700; }
    .day-chip {
      display: inline-block;
      background: var(--orange, #FF5722);
      color: #fff;
      font-size: 13px; font-weight: 700;
      padding: 3px 10px; border-radius: 20px;
