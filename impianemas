      width: 80px; height: 80px;
      border-radius: 50%;
      background: #E0F7FA;
      border: 3px solid var(--green);
      margin-bottom: 12px;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
