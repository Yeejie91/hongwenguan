    .faq-item.open .faq-q .arrow { transform: rotate(45deg); }
    .faq-a {
      display: none;
      padding: 0 20px 18px;
      font-size: 16px;
      color: #555;
      line-height: 1.75;
      border-top: 1px solid #B2EBF2;
      padding-top: 16px;
    }
    .faq-item.open .faq-a { display: block; }

    /* ─── FINAL CTA ─── */
    #final-cta {
      background: linear-gradient(135deg, #0097A7 0%, #006978 100%);
      color: #fff;
      text-align: center;
      padding: 64px 20px;
    }
    #final-cta h2 { font-size: clamp(24px, 5.5vw, 36px); font-weight: 900; margin-bottom: 12px; }
    #final-cta p  { font-size: 17px; opacity: .88; margin-bottom: 32px; max-width: 460px; margin-left: auto; margin-right: auto; }
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      max-width: 480px;
      margin: 0 auto 36px;
      text-align: left;
    }
    .contact-item {
      display: flex; align-items: flex-start; gap: 14px;
      background: rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 16px 18px;
    }
    .contact-item .icon { font-size: 22px; flex-shrink: 0; }
    .contact-item .info { font-size: 16px; line-height: 1.65; }
    .contact-item .info strong { display: block; font-size: 13px; opacity: .7; margin-bottom: 2px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .urgency-note {
      display: inline-block;
      background: var(--red);
      color: #fff;
      font-size: 15px; font-weight: 700;
      padding: 10px 26px;
      border-radius: 50px;
      margin-bottom: 28px;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: .75; }
    }

    /* ─── FOOTER ─── */
    footer {
      background: #004D57;
      color: rgba(255,255,255,0.65);
      text-align: center;
      padding: 22px;
      font-size: 14px;
    }

    /* ─── STICKY WA ─── */
    .sticky-wa {
      position: fixed; bottom: 20px; right: 20px; z-index: 200;
    }
    .sticky-wa a {
      display: flex; align-items: center; justify-content: center;
      width: 56px; height: 56px;
      background: var(--wa);
      border-radius: 50%;
      box-shadow: 0 4px 20px rgba(37,211,102,0.5);
      transition: transform .2s;
    }
    .sticky-wa a:hover { transform: scale(1.1); }
    .sticky-wa svg { width: 30px; height: 30px; fill: #fff; }

    /* ─── Responsive ─── */
    @media (min-width: 600px) {
      .pain-grid { grid-template-columns: 1fr 1fr; }
      #why .why-grid { grid-template-columns: 1fr 1fr; }
      .reading-grid { grid-template-columns: 1fr 1fr 1fr; }
      .contact-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
