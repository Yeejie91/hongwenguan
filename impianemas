      opacity: .85;
      margin-top: 5px;
    }

    /* ─── PAIN POINTS ─── */
    #pain { background: #fff; }
    .pain-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .pain-card {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      background: #FFF5F5;
      border-left: 4px solid var(--red);
      border-radius: 10px;
      padding: 18px 20px;
